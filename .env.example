# =============================================================================
# ki-db Environment Configuration
# =============================================================================

# --- Postgres (ParadeDB) ---
POSTGRES_USER=kidb
POSTGRES_PASSWORD=kidb_secret
POSTGRES_DB=kidb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DSN=postgres://kidb:kidb_secret@localhost:5432/kidb?sslmode=disable
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=2
POSTGRES_APP_USER=kidb_app
POSTGRES_APP_PASSWORD=kidb_app_secret

# --- NATS JetStream ---
NATS_URL=nats://localhost:4222
NATS_STREAM=IDX_DOCS
NATS_CONSUMER_PREFIX=kidb

# --- Tenancy ---
TENANCY_MODE=rls
TENANCY_TENANT_HEADER=X-Tenant-ID

# --- Embedding ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1024
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_BATCH_SIZE=100
# EMBEDDING_URL=  # optional; auto-derived from PROVIDER (openai=https://api.openai.com/v1/embeddings, ollama=http://localhost:11434/api/embeddings)

# --- Reranker (optional in Phase 1) ---
RERANKER_ENABLED=false
RERANKER_URL=http://localhost:8081/rerank
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Search ---
SEARCH_BM25_TOPK=200
SEARCH_ANN_TOPK=200
SEARCH_RERANK_TOPN=50
SEARCH_RRF_K=60

# --- Outbox Relay ---
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_MS=500ms
OUTBOX_MAX_RETRIES=5

# --- Worker ---
WORKER_MAX_RETRIES=8
WORKER_ACK_WAIT_SEC=30s
WORKER_MAX_ACK_PENDING=500

# --- API Server ---
INGEST_API_PORT=8080
QUERY_API_PORT=8081

# --- Dashboard ---
NEXT_PUBLIC_QUERY_API_URL=http://localhost:8081
NEXT_PUBLIC_INGEST_API_URL=http://localhost:8080

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
